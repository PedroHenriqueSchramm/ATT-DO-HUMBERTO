dim lado, area, perimetro, resp

call calcular
function calcular()

lado = cdbl(inputbox("Digite o lado do quadrado: "))
area = (lado * lado)
perimetro = lado * 4

resp = msgbox("A área do quadrado é: "& area &"" + vbnewline &_
            "O perímetro do quadrado é :"& perimetro &"" + vbnewline &_
            "Deseja fazer um novo cálculo?", vbquestion + vbyesno)

if resp = vbyes then
    call calcular
else
    wscript.quit
end if
end function
